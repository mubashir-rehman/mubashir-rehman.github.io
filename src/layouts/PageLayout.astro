---
/**
 * PageLayout.astro
 *
 * Layout for Astro-rendered pages. Wraps Base.astro and adds:
 *  - Astro View Transitions (ClientRouter) for smooth MPA navigation
 *  - Skip link (a11y), fixed-navbar offset, mobile bottom-nav offset
 *  - Astro chrome: Navbar, BottomNav, Footer
 *  - Global islands: AskMe (chatbot)
 *  - Scroll-reveal IntersectionObserver (CSS-only animation, reduced-motion safe)
 */

import Base from "@/layouts/Base.astro";
import { ClientRouter } from "astro:transitions";
import Navbar from "@/components/astro/Navbar.astro";
import BottomNav from "@/components/astro/BottomNav.astro";
import Footer from "@/components/astro/Footer.astro";
import AskMe from "@/components/AskMe";
import { buildSystemPrompt } from "@/lib/askmePrompt";

// Built once per page at build time from the JSON data — the chatbot's
// grounding can no longer drift from profile/projects/roles.
const askMePrompt = buildSystemPrompt();

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  schema?: object | object[];
}

const { title, description, canonicalPath = "/", schema } = Astro.props;
---

<Base title={title} description={description} canonicalPath={canonicalPath} schema={schema}>
  <ClientRouter />

  <a href="#main" class="skip-link">Skip to content</a>

  <Navbar />

  <!-- pt-16 clears the fixed 64px navbar. Bottom-nav clearance lives on the
       Footer (the document's last element), not here — padding on <main> left
       the footer's final line hidden behind the fixed mobile nav. -->
  <main id="main" class="min-h-dvh pt-16">
    <slot />
  </main>

  <Footer />
  <BottomNav />

  <!-- AskMe chatbot — idle hydration; prompt generated from JSON at build -->
  <AskMe client:idle systemPrompt={askMePrompt} />

  <!-- Scroll-reveal activation (re-runs after view transitions) -->
  <script is:inline>
    (function () {
      function activateReveals() {
        var els = document.querySelectorAll(".reveal:not(.is-visible)");
        if (!els.length) return;
        if (
          !("IntersectionObserver" in window) ||
          window.matchMedia("(prefers-reduced-motion: reduce)").matches
        ) {
          els.forEach(function (el) { el.classList.add("is-visible"); });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
        );
        els.forEach(function (el) { io.observe(el); });
      }
      activateReveals();
      document.addEventListener("astro:page-load", activateReveals);
    })();
  </script>
</Base>
