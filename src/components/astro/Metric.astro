---
interface Props {
  value: string;
  label: string;
  class?: string;
}
const { value, label, class: className = "" } = Astro.props;
---
<div
  class={`flex flex-col items-center justify-center rounded-xl border border-border bg-card px-3 py-5 text-center transition-colors hover:border-primary/40 ${className}`}
>
  <div class="font-body text-3xl font-bold tracking-tight text-foreground tabular-nums sm:text-4xl">
    {value}
  </div>
  <div class="mt-1.5 text-xs font-medium uppercase tracking-wide text-muted-foreground leading-tight">
    {label}
  </div>
</div>
