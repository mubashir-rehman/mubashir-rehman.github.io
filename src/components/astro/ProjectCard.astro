---
interface Project {
  id: string;
  title: string;
  description: string;
  tags: string[];
  github?: string;
  demo?: string;
  metrics: string[];
  featured: boolean;
}

interface Props {
  project: Project;
  class?: string;
}

const { project, class: className = "" } = Astro.props;
---
<div class={`flex flex-col rounded-lg border border-border bg-card p-6 h-full transition-shadow hover:shadow-md ${className}`}>
  <!-- Title -->
  <h3 class="text-base font-semibold tracking-tight text-foreground mb-2">
    {project.title}
  </h3>

  <!-- Description -->
  <p class="text-sm text-muted-foreground leading-relaxed flex-1 line-clamp-4">
    {project.description}
  </p>

  <!-- Metrics -->
  {project.metrics.length > 0 && (
    <ul class="mt-4 space-y-1.5">
      {project.metrics.slice(0, 3).map((m) => (
        <li class="flex items-start gap-2.5 text-sm text-foreground">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-primary" aria-hidden="true"><polyline points="20 6 9 17 4 12" /></svg>
          {m}
        </li>
      ))}
    </ul>
  )}

  <!-- Tags -->
  <div class="mt-4 flex flex-wrap gap-1.5">
    {project.tags.slice(0, 6).map((tag) => (
      <span class="chip">{tag}</span>
    ))}
  </div>

  <!-- Links -->
  {(project.github || project.demo) && (
    <div class="mt-4 flex gap-4">
      {project.github && (
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-primary hover:underline"
        >
          Source →
        </a>
      )}
      {project.demo && (
        <a
          href={project.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-medium text-primary hover:underline"
        >
          Live →
        </a>
      )}
    </div>
  )}
</div>
