---
interface Project {
  id: string;
  title: string;
  description: string;
  tags: string[];
  github?: string;
  demo?: string;
  metrics: string[];
  featured: boolean;
}

interface Props {
  project: Project;
  class?: string;
}

const { project, class: className = "" } = Astro.props;
---
<div class={`flex flex-col rounded-xl border border-border bg-card p-6 h-full transition-shadow hover:shadow-md ${className}`}>
  <!-- Tags -->
  <div class="flex flex-wrap gap-1.5 mb-3">
    {project.tags.slice(0, 4).map((tag) => (
      <span class="rounded-full bg-secondary px-2.5 py-0.5 text-xs font-medium text-secondary-foreground">
        {tag}
      </span>
    ))}
  </div>

  <!-- Title -->
  <h3 class="font-heading text-lg font-bold leading-snug text-foreground mb-2">
    {project.title}
  </h3>

  <!-- Description -->
  <p class="text-sm text-muted-foreground leading-relaxed flex-1 line-clamp-4">
    {project.description}
  </p>

  <!-- Metrics -->
  {project.metrics.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {project.metrics.slice(0, 3).map((m) => (
        <span class="rounded-full border border-border px-2.5 py-0.5 text-xs text-muted-foreground">
          {m}
        </span>
      ))}
    </div>
  )}

  <!-- Links -->
  {(project.github || project.demo) && (
    <div class="mt-4 flex gap-4">
      {project.github && (
        <a
          href={project.github}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-semibold text-primary hover:underline"
        >
          GitHub →
        </a>
      )}
      {project.demo && (
        <a
          href={project.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs font-semibold text-primary hover:underline"
        >
          Demo →
        </a>
      )}
    </div>
  )}
</div>
