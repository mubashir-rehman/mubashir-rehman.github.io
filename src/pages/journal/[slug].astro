---
/**
 * journal/[slug].astro — static blog post pages.
 * Markdown rendered to static HTML at build time via react-markdown
 * (no client directive → zero client JS).
 */
import PageLayout from "@/layouts/PageLayout.astro";
import Markdown from "@/components/Markdown";
import journal from "@/data/journal.json";

export function getStaticPaths() {
  return journal.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const SITE = "https://mubashir-rehman.is-a.dev";

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: entry.title,
  description: entry.excerpt,
  datePublished: entry.date,
  dateModified: entry.date,
  url: `${SITE}/journal/${entry.slug}`,
  image: `${SITE}/og-image.png`,
  inLanguage: "en",
  keywords: entry.tags?.join(", "),
  author: { "@type": "Person", name: "Mubashir Rehman", url: SITE },
  publisher: { "@type": "Person", name: "Mubashir Rehman", url: SITE },
  isPartOf: { "@type": "Blog", name: "Mubashir Rehman — Blog", url: `${SITE}/journal` },
};
---

<PageLayout
  title={entry.title}
  description={entry.excerpt}
  canonicalPath={`/journal/${entry.slug}`}
  schema={articleSchema}
>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6 md:py-20">
    <a
      href="/journal"
      class="inline-flex items-center gap-1.5 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      All posts
    </a>

    <header class="mt-8">
      <p class="font-mono text-xs text-muted-foreground">
        {entry.date} · Mubashir Rehman
      </p>
      <h1 class="mt-3 text-3xl font-bold leading-tight tracking-tight sm:text-4xl">
        {entry.title}
      </h1>
      <div class="mt-4 flex flex-wrap gap-1.5">
        {
          entry.tags?.map((t) => (
            <span class="chip">
              {t}
            </span>
          ))
        }
      </div>
    </header>

    <div class="prose prose-sm sm:prose-base mt-10 max-w-none">
      <Markdown content={entry.content} />
    </div>
  </article>
</PageLayout>
