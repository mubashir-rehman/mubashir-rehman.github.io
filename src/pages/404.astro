---
/**
 * 404.astro — static not-found page.
 */
import PageLayout from "@/layouts/PageLayout.astro";
---

<PageLayout title="404 — Not Found" canonicalPath="/404">
  <section class="flex min-h-[60vh] items-center">
    <div class="mx-auto max-w-6xl px-4 py-20 text-center sm:px-6">
      <p class="metric-value text-7xl text-primary sm:text-8xl">404</p>
      <h1 class="mt-6 text-2xl font-bold tracking-tight sm:text-3xl">
        This page doesn't exist.
      </h1>
      <p class="mx-auto mt-3 max-w-[45ch] text-muted-foreground">
        The link may be stale — everything worth seeing is one click away.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/"
          class="press-feedback inline-flex items-center rounded-full bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
        >
          Back home
        </a>
        <a
          href="/projects"
          class="press-feedback inline-flex items-center rounded-full border border-border bg-card px-5 py-3 text-sm font-semibold text-foreground transition-colors hover:bg-accent"
        >
          View work
        </a>
      </div>
    </div>
  </section>
</PageLayout>
