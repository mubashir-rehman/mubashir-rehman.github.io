---
/**
 * journal.astro — static blog index (technical writing).
 */
import PageLayout from "@/layouts/PageLayout.astro";
import journal from "@/data/journal.json";

const posts = [...journal].sort((a, b) => (a.date < b.date ? 1 : -1));

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Mubashir Rehman — Blog",
  url: "https://mubashir-rehman.is-a.dev/journal",
  author: { "@type": "Person", name: "Mubashir Rehman" },
};
---

<PageLayout
  title="Blog"
  description="Technical writing by Mubashir Rehman — articles on backend engineering, distributed systems, Python, and software architecture."
  canonicalPath="/journal"
  schema={blogSchema}
>
  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20">
      <p class="eyebrow">Writing</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Blog</h1>
      <p class="mt-5 max-w-[60ch] text-lg text-muted-foreground">
        Notes from building things — engineering decisions, trade-offs, and the occasional
        detour.
      </p>
    </div>
  </section>

  <section class="bg-card">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <ol class="space-y-5">
        {
          posts.map((post) => (
            <li>
              <a
                href={`/journal/${post.slug}`}
                class="press-feedback group block rounded-lg border border-border bg-background p-6 transition-colors hover:border-primary/50"
              >
                <p class="font-mono text-xs text-muted-foreground">{post.date}</p>
                <h2 class="mt-2 text-lg font-semibold tracking-tight group-hover:text-primary">
                  {post.title}
                </h2>
                <p class="mt-2 max-w-[75ch] text-sm leading-relaxed text-muted-foreground">
                  {post.excerpt}
                </p>
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {post.tags?.map((t) => (
                    <span class="chip">
                      {t}
                    </span>
                  ))}
                </div>
              </a>
            </li>
          ))
        }
      </ol>
    </div>
  </section>
</PageLayout>
