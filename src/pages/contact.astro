---
/**
 * contact.astro — static Contact page with dual paths:
 * recruiters (résumé + role pages) and clients (project brief).
 */
import PageLayout from "@/layouts/PageLayout.astro";
import profile from "@/data/profile.json";
import roles from "@/data/roles.json";
---

<PageLayout
  title="Contact"
  description="Get in touch with Mubashir Rehman — Backend Engineer open to remote roles in any timezone (and on-site in Lahore), and available for contract/project work."
  canonicalPath="/contact"
>
  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-20">
      <p class="eyebrow">Contact</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">Let's talk.</h1>
      <p class="mt-5 max-w-[60ch] text-lg text-muted-foreground">
        {profile.availabilityNote} — and available for contract and project work.
        I reply within a day.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={`mailto:${profile.email}`}
          class="press-feedback inline-flex items-center gap-2 rounded-full bg-primary px-5 py-3 text-sm font-semibold text-primary-foreground transition-colors hover:bg-primary/90"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          {profile.email}
        </a>
        <a
          href={profile.socialLinks.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="press-feedback inline-flex items-center rounded-full border border-border bg-card px-5 py-3 text-sm font-semibold text-foreground transition-colors hover:bg-accent"
        >
          WhatsApp
        </a>
        <a
          href={profile.socialLinks.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="press-feedback inline-flex items-center rounded-full border border-border bg-card px-5 py-3 text-sm font-semibold text-foreground transition-colors hover:bg-accent"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </section>

  <section class="bg-card">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <div class="grid gap-6 md:grid-cols-2">
        <!-- Recruiters -->
        <div class="rounded-lg border border-border bg-background p-7">
          <p class="eyebrow">Hiring?</p>
          <h2 class="mt-3 text-xl font-semibold tracking-tight">For recruiters</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
            Grab the résumé that matches your role, or start from the role pages — each has
            the relevant projects, stack, and FAQs.
          </p>
          <ul class="mt-5 space-y-2.5">
            {
              roles.map((r) => (
                <li>
                  <a href={`/for/${r.slug}`} class="text-sm font-medium text-primary hover:underline">
                    {r.label} →
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Clients -->
        <div class="rounded-lg border border-border bg-background p-7">
          <p class="eyebrow">Building?</p>
          <h2 class="mt-3 text-xl font-semibold tracking-tight">For clients</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
            Email me a short brief — what you're building, current stack (if any), and a
            rough timeline. I'll reply with questions or a scoped proposal.
          </p>
          <p class="mt-5">
            <a href="/services" class="text-sm font-medium text-primary hover:underline">
              Services &amp; engagement models →
            </a>
          </p>
          <p class="mt-2">
            <a
              href={`mailto:${profile.email}?subject=Project%20brief`}
              class="text-sm font-medium text-primary hover:underline"
            >
              Send a project brief →
            </a>
          </p>
        </div>
      </div>

      <p class="mt-10 font-mono text-xs text-muted-foreground">
        {profile.location} · {profile.phone} · GitHub:
        <a href={profile.socialLinks.github} target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">
          mubashir-rehman
        </a>
      </p>
    </div>
  </section>
</PageLayout>
