# Astro exposes client-side env vars with the PUBLIC_ prefix (import.meta.env.PUBLIC_*).
# Copy this file to .env and fill in your values.

# Groq API Key — get yours free at https://console.groq.com
# Used by the AskMe chatbot (browser-side, no backend required)
PUBLIC_GROQ_API_KEY=your_groq_api_key_here

# Giscus Configuration
# Get these values from https://giscus.app
PUBLIC_GISCUS_REPO=your-username/your-repo
PUBLIC_GISCUS_REPO_ID=REPLACE_WITH_REPO_ID
PUBLIC_GISCUS_CATEGORY=General
PUBLIC_GISCUS_CATEGORY_ID=REPLACE_WITH_CATEGORY_ID
