# Groq API Key — get yours free at https://console.groq.com
# Used by the AskMe chatbot (browser-side, no backend required)
VITE_GROQ_API_KEY=your_groq_api_key_here

# Giscus Configuration
# Get these values from https://giscus.app
VITE_GISCUS_REPO=your-username/your-repo
VITE_GISCUS_REPO_ID=REPLACE_WITH_REPO_ID
VITE_GISCUS_CATEGORY=General
VITE_GISCUS_CATEGORY_ID=REPLACE_WITH_CATEGORY_ID
